{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the GovAssist+ application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "mobile": { "type": "string", "description": "The user's mobile number." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role." },
        "createdAt": { "type": "timestamp", "description": "When the user account was created." },
        "lastLoginAt": { "type": "timestamp", "description": "When the user last logged in." }
      },
      "required": ["uid", "mobile", "role", "createdAt", "lastLoginAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    }
  }
}
